{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Exit",
  "type": "object",
  "required": ["id", "from_id", "to_id", "direction", "label"],
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^exit_"
    },
    "from_id": {
      "type": "string",
      "pattern": "^location_"
    },
    "to_id": {
      "type": "string",
      "pattern": "^location_"
    },
    "direction": {
      "type": "string",
      "enum": ["north", "south", "east", "west", "up", "down", "northeast", "northwest", "southeast", "southwest", "enter", "exit", "through", "back"]
    },
    "label": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "requires_item": {
      "type": "string"
    },
    "requires_level": {
      "type": "integer",
      "minimum": 1
    },
    "is_hidden": {
      "type": "boolean"
    },
    "order": {
      "type": "integer"
    },
    "travel_time_base": {
      "type": "integer",
      "minimum": 1
    },
    "difficulty": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10
    },
    "terrain_type": {
      "type": "string"
    }
  }
}
