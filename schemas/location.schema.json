{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Location",
  "type": "object",
  "required": ["id", "name", "description", "type", "is_safe", "_zone"],
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^location_"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "enum": ["town", "wilderness", "dungeon", "cave", "building", "road", "water", "settlement", "ruins", "forest", "indoor", "outdoor", "city", "shop", "inn", "cemetery", "mountain"]
    },
    "is_safe": {
      "type": "boolean"
    },
    "_zone": {
      "type": "string"
    },
    "full_description": {
      "type": "string"
    },
    "lore_en": {
      "type": "string"
    },
    "image_prompt": {
      "type": "string"
    },
    "image_url": {
      "type": "string"
    },
    "animated_image_url": {
      "type": "string"
    },
    "animated_image_prompt": {
      "type": "string"
    },
    "ambient_sound": {
      "type": "string"
    },
    "music": {
      "type": "string"
    },
    "combat_music": {
      "type": "string"
    },
    "district_id": {
      "oneOf": [{"type": "string"}, {"type": "null"}]
    },
    "map_x": {
      "type": "number"
    },
    "map_y": {
      "type": "number"
    },
    "open_hours": {
      "oneOf": [
        {"type": "object"},
        {"type": "null"}
      ]
    }
  }
}
